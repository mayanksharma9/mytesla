    "logs": "firebase functions:log"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.1.1",
    "firebase-functions": "^5.0.1",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "private": true
}
