rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Vehicles and all nested telemetry
    match /vehicles/{vin} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }
    
    // 2. Specialized collections for history viewing
    match /trip_history/{id} {
      allow read, write: if true;
    }
    
    match /charging_history/{id} {
      allow read, write: if true;
    }

    // Default catch-all for troubleshooting
    match /{document=**} {
      allow read, write: if true;
    }
  }
}