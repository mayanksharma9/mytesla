rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY: Broad access for debugging PERMISSION_DENIED and DEVELOPER_ERROR
    match /vehicles/{vin}/{allSubcollections=**} {
      allow read, write: if true;
    }
    
    match /trip_history/{id} {
      allow read, write: if true;
    }
    
    match /charging_history/{id} {
      allow read, write: if true;
    }

    // Default allow for debugging
    match /{document=**} {
      allow read, write: if true;
    }
  }
}