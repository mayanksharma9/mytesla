rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Telemetry documents — written by the Flutter app (anonymous auth) after
    // every REST poll, and by the proxy backend (anonymous auth via REST API).
    // Only authenticated users may read or write their own vehicle's document.
    match /telemetry/{vin} {
      allow read, write: if request.auth != null;
    }

    // Trip and charging history are written locally by the app.
    match /trip_history/{id} {
      allow read, write: if request.auth != null;
    }

    match /charging_history/{id} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
  }
}
