rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /vehicles/{vin}/{allSubcollections=**} {
      allow read, write: if request.auth != null;
    }
    match /charging_history/{id}/{allSubcollections=**} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}